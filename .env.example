SPRING_PROFILES_ACTIVE=local

# Database
DB_URL=jdbc:postgresql://localhost:5432/mio
DB_USERNAME=mio
DB_PASSWORD=mio

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT — 반드시 32자 이상
JWT_SECRET=your-32-char-or-longer-secret-key-here

# Kakao (기본값 사용 시 생략 가능)
KAKAO_API_URL=https://kapi.kakao.com

# Apple — Apple Developer에서 번들 ID 확인
APPLE_APP_ID=com.example.mio
APPLE_JWKS_URL=https://appleid.apple.com/auth/keys

# OpenAI (2차 개발)
OPENAI_API_KEY=

# Firebase Admin SDK — Android FCM
# base64로 인코딩된 service-account.json 내용
FCM_CREDENTIALS_JSON=

# AES-256 암호화 키 (32 bytes base64)
APP_ENCRYPTION_KEY=your-32-byte-base64-encoded-encryption-key
APP_ENCRYPTION_DEK_ID=app-key-v1

# HIRA API
HIRA_API_KEY=
