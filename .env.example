SPRING_PROFILES_ACTIVE=local

# Database
DB_URL=jdbc:postgresql://localhost:5432/mio
DB_USERNAME=mio
DB_PASSWORD=mio

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT — 반드시 32자 이상
JWT_SECRET=your-32-char-or-longer-secret-key-here

# Kakao (기본값 사용 시 생략 가능)
KAKAO_API_URL=https://kapi.kakao.com

# Apple — Apple Developer에서 번들 ID 확인
APPLE_APP_ID=com.example.mio
APPLE_JWKS_URL=https://appleid.apple.com/auth/keys

# OpenAI (2차 개발)
OPENAI_API_KEY=

# Firebase Admin SDK — Android FCM
# base64로 인코딩된 service-account.json 내용
FCM_CREDENTIALS_JSON=

# Apple APNs — iOS 푸시 알림 (Apple Developer에서 발급)
# APNS_KEY_CONTENT 우선 사용 (프로덕션 권장): .p8 파일 전체를 base64 인코딩한 값
# 인코딩 방법(macOS): base64 -i AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
# 인코딩 방법(Linux): base64 -w 0 AuthKey_XXXXXXXXXX.p8
APNS_KEY_CONTENT=
# APNS_KEY_PATH는 폴백 (로컬 개발 시 파일 경로 직접 지정 가능)
APNS_KEY_PATH=
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.example.mio
APNS_IS_PRODUCTION=false

# AES-256 암호화 키 (32 bytes base64)
APP_ENCRYPTION_KEY=your-32-byte-base64-encoded-encryption-key
APP_ENCRYPTION_DEK_ID=app-key-v1
# HMAC key for semantic belief identity (32+ bytes; AES key와 별도 관리)
APP_BELIEF_IDENTITY_HMAC_KEY=replace-with-a-separate-32-byte-or-longer-secret

# HIRA API
HIRA_API_KEY=
